# Copy to `.env` and edit. Inspect auto-loads .env from the working directory.

# ---- Ollama via OpenAI-compatible endpoint (use openai/<model> in --model) ----
OPENAI_BASE_URL=http://10.100.203.130:11434/v1
OPENAI_API_KEY=ollama

# ---- Native Ollama provider (use ollama/<model> in --model) ----
# Better for thinking-mode models (Qwen3, etc.)
OLLAMA_BASE_URL=http://10.100.203.130:11434

# ---- Hosted providers (uncomment as needed) ----
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# ---- Inspect knobs ----
# INSPECT_LOG_DIR=./logs
# INSPECT_EVAL_MAX_CONNECTIONS=4
