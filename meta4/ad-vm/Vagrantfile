# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # WinRM: plaintext + basic-auth-only survives DCPROMO SAM migration.
  # NTLM/negotiate caches session tickets against the local SAM, which
  # Install-ADDSForest strips; basic auth re-runs the full lookup each
  # call so once bootstrap.ps1 creates CORP\vagrant, reconnect succeeds.
  # (Pattern from rgl/windows-domain-controller-vagrant + DetectionLab.)
  config.winrm.username = "vagrant"
  config.winrm.password = "vagrant"
  config.winrm.transport = :plaintext
  config.winrm.basic_auth_only = true
  config.winrm.retry_limit = 20
  config.winrm.timeout = 300

  # ----- DC: corp.local forest root -----
  config.vm.define "dc" do |dc|
    dc.vm.box = "jborean93/WindowsServer2019"
    dc.vm.hostname = "corp-dc01"
    dc.vm.boot_timeout = 1200
    dc.vm.communicator = "winrm"
    dc.vm.network "private_network", ip: "10.20.30.5"

    dc.vm.provider "virtualbox" do |vb|
      vb.name = "meta4-ad-dc"
      vb.memory = 3072
      vb.cpus = 2
      vb.linked_clone = true
    end

    dc.vm.provision "shell",
      path: "provision/dc-baseline.ps1",
      privileged: true

    dc.vm.provision :reload

    dc.vm.provision "shell",
      path: "provision/dc-baseline.ps1",
      privileged: true
  end

  # ----- CA: Enterprise PKI on member server -----
  config.vm.define "ca" do |ca|
    ca.vm.box = "jborean93/WindowsServer2019"
    ca.vm.hostname = "corp-ca01"
    ca.vm.boot_timeout = 1200
    ca.vm.communicator = "winrm"
    ca.vm.network "private_network", ip: "10.20.30.6"

    ca.vm.provider "virtualbox" do |vb|
      vb.name = "meta4-ad-ca"
      vb.memory = 2048
      vb.cpus = 2
      vb.linked_clone = true
    end

    ca.vm.provision "shell",
      path: "provision/ca-baseline.ps1",
      privileged: true

    ca.vm.provision :reload

    ca.vm.provision "shell",
      path: "provision/ca-baseline.ps1",
      privileged: true
  end

  # ----- Attacker: Kali rolling -----
  config.vm.define "attacker" do |atk|
    atk.vm.box = "kalilinux/rolling"
    atk.vm.hostname = "kali-attacker"
    atk.vm.network "private_network", ip: "10.20.30.10"

    atk.vm.provider "virtualbox" do |vb|
      vb.name = "meta4-ad-attacker"
      vb.memory = 3072
      vb.cpus = 2
      vb.linked_clone = true
    end

    atk.vm.provision "shell",
      path: "provision/attacker-baseline.sh",
      privileged: true
  end
end
