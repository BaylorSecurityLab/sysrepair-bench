# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Kernel-LPE VM for meta4 scenarios S19, S21, S22.
#
# Provisions an Ubuntu 22.04 VM with a pinned vulnerable kernel and Docker
# pre-installed. The three kernel-level LPE scenarios (Dirty Pipe,
# GameOverlay, nf_tables UAF) are run as Docker containers INSIDE this VM
# so they share its vulnerable kernel.
#
# Usage:
#   vagrant up
#   vagrant ssh
#   cd /meta4 && sudo docker build -t s21 scenario-21 && sudo docker run --rm --privileged s21 bash /verify.sh
#
# Kernel landing: install-old-kernel.sh (stage 1) explicitly installs
# 5.15.0-25-generic (22.04 GA kernel, pre-GameOverlay and pre-nf_tables
# fixes) and points GRUB at it; Vagrant reboots; provision.sh (stage 2)
# then holds that kernel and installs Docker on top. We do NOT rely on
# the box image shipping a vulnerable kernel by itself — Canonical
# refreshes the jammy64 box periodically and the shipped ABI has since
# moved past the fix lines.
#
# S19 (Dirty Pipe) was fixed before Ubuntu 22.04 GA — see README for
# the separate 20.04 HWE kernel path.

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "meta4-kernel"

  config.vm.provider "virtualbox" do |vb|
    vb.name   = "meta4-kernel-lpe"
    vb.memory = 4096
    vb.cpus   = 2
  end

  # Stage 1: install the old kernel, repoint GRUB, reboot into it.
  config.vm.provision "shell", path: "install-old-kernel.sh", reboot: true
  # Stage 2: runs on the old kernel — hold it, install Docker, report.
  config.vm.provision "shell", path: "provision.sh"

  # Mount the meta4 scenario directories into the VM
  config.vm.synced_folder "..", "/meta4"
end
