# Enforce Unix line endings on shell scripts so `docker build` on Windows
# hosts does not ship CRLF shebangs that break `#!/bin/bash` inside Linux
# containers. Windows scenarios intentionally use CRLF for .ps1 / .cmd.
*.sh       text eol=lf
Dockerfile text eol=lf
*.cnf      text eol=lf
*.conf     text eol=lf
*.json     text eol=lf

*.ps1      text eol=crlf
*.cmd      text eol=crlf
*.bat      text eol=crlf
