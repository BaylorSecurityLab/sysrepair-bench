# Hivestorm scenario-14 — FreeBSD 13 host.
# Installs nginx, then runs seed.sh to plant misconfigurations.
# verify.sh is shipped to /var/db/sysrepair/ for later invocation.

require 'json'

ROLES_PATH = File.join(File.dirname(__FILE__), 'build', 'roles.json')
unless File.exist?(ROLES_PATH)
  abort "missing #{ROLES_PATH}. Run `hivestorm/prepare.sh 14` first."
end

Vagrant.configure("2") do |config|
  config.vm.box = "freebsd/FreeBSD-13.2-RELEASE"
  config.vm.hostname = "hs14-bsd"
  # FreeBSD boxes default to the `vagrant` user with key-based SSH.
  config.ssh.shell = "sh"
  config.vm.base_mac = nil

  config.vm.provider "virtualbox" do |vb|
    vb.gui = false
    vb.memory = 2048
    vb.cpus   = 2
    # FreeBSD requires the 82540EM NIC; box should already set this,
    # but we re-assert for older templates.
    vb.customize ["modifyvm", :id, "--nictype1", "Am79C973"]
    vb.customize ["modifyvm", :id, "--nictype2", "Am79C973"]
  end

  config.vm.boot_timeout = 900

  config.vm.network "private_network", ip: "192.168.56.14"

  # FreeBSD rsync'd synced folder — NFS is flaky on Win hosts.
  config.vm.synced_folder ".", "/vagrant", type: "rsync",
    rsync__exclude: [".vagrant/"]

  # Stage 1: bootstrap pkg, install baseline services, then seed.
  config.vm.provision "shell",
    name: "bootstrap-and-seed",
    privileged: true,
    inline: <<~SH
      set -eu
      export ASSUME_ALWAYS_YES=yes

      # Bootstrap pkg if missing (first boot of a fresh box).
      if ! command -v pkg >/dev/null 2>&1; then
          env ASSUME_ALWAYS_YES=yes pkg bootstrap -f
      fi

      # Baseline services the scenario expects to survive.
      pkg install -y nginx netcat sudo bash

      # Roles go to a non-obvious path so the agent can't trivially find the
      # answer key. seed.sh and verify.sh both read from this location.
      mkdir -p /root/.sysrepair
      chmod 0700 /root/.sysrepair
      cp /vagrant/build/roles.json /root/.sysrepair/config
      chmod 0400 /root/.sysrepair/config

      # Seed script only — verify.sh is re-uploaded by the Inspect scorer at
      # eval time and must NOT be left on the VM beforehand.
      cp /vagrant/seed.sh /root/.sysrepair/seed.sh
      chmod 0700 /root/.sysrepair/seed.sh

      # Enable baseline services BEFORE seeding so we have something
      # for the verifier to confirm is still running.
      sysrc sshd_enable=YES
      sysrc nginx_enable=YES
      service sshd   start || true
      service nginx  start || true

      # Run the seeder, then erase both it and roles.json.
      # roles.json is re-uploaded by the Inspect scorer at eval time
      # (alongside verify.sh), so it must not persist on the VM.
      /root/.sysrepair/seed.sh
      rm -f /root/.sysrepair/seed.sh
      rm -f /root/.sysrepair/config

      # Anti-contamination: /vagrant is just an rsync copy of the host
      # checkout (contains seed.sh, verify.sh, roles.json, task.md).
      # Delete it so the agent cannot read the answer key.
      rm -rf /vagrant
    SH
end
